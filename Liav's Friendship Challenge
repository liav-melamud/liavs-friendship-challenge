// ─── Create ─────────────────────────────────────────────────────────────────
function goCreate(){
  challengeType='public';
  document.getElementById('typePublicBtn').className='type-btn sel-pub';
  document.getElementById('typePrivBtn').className='type-btn';
  document.getElementById('creatorNameInp').value='';
  document.getElementById('titleInp').value='';
  document.getElementById('deleteCodeInp').value='';
  buildQForm();
  showScreen('create');
}
 
function setChallengeType(t){
  challengeType=t;
  document.getElementById('typePublicBtn').className=t==='public'?'type-btn sel-pub':'type-btn';
  document.getElementById('typePrivBtn').className=t==='private'?'type-btn sel-priv':'type-btn';
}
 
function buildQForm(){
  const container=document.getElementById('questions-form');
  container.innerHTML='';
  for(let i=0;i<5;i++){
    const div=document.createElement('div');
    div.className='q-card';
    div.innerHTML=`
      <div class="q-num">שאלה ${i+1}</div>
      <input class="inp" id="q${i}" placeholder="כתוב את השאלה או המשפט..." style="margin-bottom:0">
      <div class="toggle-row">
        <button class="tbtn tbtn-t" id="q${i}_t" onclick="setQAnswer(${i},true)">✓ נכון</button>
        <button class="tbtn tbtn-f" id="q${i}_f" onclick="setQAnswer(${i},false)">✗ לא נכון</button>
      </div>`;
    container.appendChild(div);
  }
}
 
const qAnswers=[null,null,null,null,null];
function setQAnswer(i,v){
  qAnswers[i]=v;
  document.getElementById(`q${i}_t`).className='tbtn tbtn-t'+(v===true?' on':'');
  document.getElementById(`q${i}_f`).className='tbtn tbtn-f'+(v===false?' on':'');
}
 
function handleCreateSubmit(){
  const creator=document.getElementById('creatorNameInp').value.trim();
  const title=document.getElementById('titleInp').value.trim();
  const delCode=document.getElementById('deleteCodeInp').value.trim();
  if(!creator) return alert('כתוב את שמך');
  if(!title) return alert('כתוב כותרת לאתגר');
  if(!delCode) return alert('כתוב קוד מחיקה');
  const questions=[];
  for(let i=0;i<5;i++){
    const t=document.getElementById(`q${i}`).value.trim();
    if(!t) return alert(`שאלה ${i+1} ריקה`);
    if(qAnswers[i]===null) return alert(`סמן תשובה לשאלה ${i+1}`);
    questions.push({text:t,answer:qAnswers[i]});
  }
  const code=challengeType==='private'?genCode():null;
  const id=Date.now().toString();
  const data={title,creatorName:creator,type:challengeType,code,id,deleteCode:delCode,questions};
  if(challengeType==='public'){
    publicChallenges.push(data);
    store(PUB_KEY,publicChallenges);
  } else {
    store(privKey(code),data);
  }
  challenge=data; scores=[];
  // render created screen
  document.getElementById('created-info').innerHTML=`האתגר של <strong style="color:#e94560">${creator}</strong> <span class="badge ${challengeType==='public'?'badge-pub':'badge-priv'}">${challengeType==='public'?'🌍 ציבורי':'🔐 פרטי'}</span>`;
  document.getElementById('created-title').textContent=`"${title}"`;
  if(challengeType==='private'){
    document.getElementById('priv-code-text').textContent=code;
    document.getElementById('priv-code-box').classList.remove('hidden');
  } else {
    document.getElementById('priv-code-box').classList.add('hidden');
  }
  showScreen('created');
}
 
// ─── Play ────────────────────────────────────────────────────────────────────
function goPlay(){
  document.getElementById('playerNameInp').value='';
  renderEnterName();
  showScreen('enter-name');
}
 
function renderEnterName(){
  document.getElementById('en-badge').className='badge '+(challenge.type==='public'?'badge-pub':'badge-priv');
  document.getElementById('en-badge').textContent=challenge.type==='public'?'🌍 ציבורי':'🔐 פרטי';
  document.getElementById('en-creator').textContent=challenge.creatorName;
  document.getElementById('en-title').textContent=`"${challenge.title}"`;
}
 
function startPlaying(){
  const name=document.getElementById('playerNameInp').value.trim();
  if(!name) return alert('כתוב את שמך');
  window._playerName=name;
  currentQ=0; playerAnswers=[]; selectedAnswer=null;
  renderPlayScreen();
  showScreen('play');
}
 
function renderPlayScreen(){
  document.getElementById('play-qnum').textContent=`שאלה ${currentQ+1} מתוך 5`;
  document.getElementById('play-player').textContent=window._playerName;
  document.getElementById('play-creator').textContent=`האתגר של ${challenge.creatorName}`;
  document.getElementById('play-question').textContent=challenge.questions[currentQ].text;
  // progress
  let dots='';
  for(let i=0;i<5;i++) dots+=`<div class="pdot${i<=currentQ?' done':''}"></div>`;
  document.getElementById('progress-dots').innerHTML=dots;
  // answers
  document.getElementById('ansTrue').className='ans-btn ans-t';
  document.getElementById('ansFalse').className='ans-btn ans-f';
  selectedAnswer=null;
  document.getElementById('nextBtn').style.opacity='.5';
  document.getElementById('nextBtn').textContent=currentQ<4?'הבא ←':'סיים! 🎯';
}
 
function selectAnswer(v){
  selectedAnswer=v;
  document.getElementById('ansTrue').className='ans-btn ans-t'+(v===true?' on':'');
  document.getElementById('ansFalse').className='ans-btn ans-f'+(v===false?' on':'');
  document.getElementById('nextBtn').style.opacity='1';
}
 
function nextQuestion(){
  if(selectedAnswer===null) return;
  playerAnswers.push(selectedAnswer);
  if(currentQ<4){currentQ++;renderPlayScreen();}
  else{
    const score=playerAnswers.filter((a,i)=>a===challenge.questions[i].answer).length;
    saveScore(window._playerName,score);
    renderResult(score);
    showScreen('result');
  }
}
 
function saveScore(name,score){
  const key=challenge.type==='public'?pubScores(challenge.id):privScores(challenge.code);
  scores=load(key)||[];
  scores.push({name,score,time:Date.now()});
  scores.sort((a,b)=>b.score-a.score);
  store(key,scores);
}
 
function renderResult(score){
  document.getElementById('result-score').textContent=`${score}/5`;
  document.getElementById('result-label').textContent=score===5?'🏆 מושלם! כל הכבוד!':score>=3?'👏 כל הכבוד!':'😅 נסה שוב בפעם הבאה!';
  let rows='';
  challenge.questions.forEach((q,i)=>{
    const ok=playerAnswers[i]===q.answer;
    rows+=`<div class="result-row ${ok?'res-ok':'res-no'}">
      <span>${ok?'✓':'✗'}</span>
      <span style="flex:1;color:#e2e8f0;font-size:.88rem">${q.text}</span>
      <span style="color:${ok?'#2ecc71':'#e94560'};font-size:.78rem;font-weight:700">${q.answer?'נכון':'לא נכון'}</span>
    </div>`;
  });
  document.getElementById('result-rows').innerHTML=rows;
}
 
// ─── Leaderboard ─────────────────────────────────────────────────────────────
function showLeaderboard(){
  const key=challenge.type==='public'?pubScores(challenge.id):privScores(challenge.code);
  scores=load(key)||[];
  document.getElementById('lb-badge').innerHTML=`<span class="badge ${challenge.type==='public'?'badge-pub':'badge-priv'}">${challenge.type==='public'?'🌍 ציבורי':'🔐 פרטי'}</span>`;
  document.getElementById('lb-title').textContent=challenge.title;
  const rankCls=['gold','silver','bronze'];
  let rows='';
  if(scores.length===0){rows='<div class="empty">עדיין אין משתתפים. שתף!</div>';}
  else scores.forEach((s,i)=>{
    rows+=`<div class="lb-row">
      <div class="rank ${rankCls[i]||''}">#${i+1}</div>
      <div style="flex:1;color:#e2e8f0;font-weight:700;font-size:.95rem">${s.name}</div>
      <div style="font-family:'Fredoka One',cursive;font-size:1.2rem;background:linear-gradient(135deg,#ff6aad,#ffb347);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">${s.score}/5</div>
    </div>`;
  });
  document.getElementById('lb-rows').innerHTML=rows;
  showScreen('leaderboard');
}
 
