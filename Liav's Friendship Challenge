// ─── Animated Background ──────────────────────────────────────────────────────
(function(){
  const canvas=document.getElementById('bgCanvas');
  const ctx=canvas.getContext('2d');
  let W=canvas.width=window.innerWidth,H=canvas.height=window.innerHeight;
  window.addEventListener('resize',()=>{W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;});
  const sc=[[255,100,130],[255,180,60],[100,220,255],[180,100,255],[80,255,180],[255,255,120],[255,120,255]];
  const stars=Array.from({length:180},()=>{
    const c=sc[Math.floor(Math.random()*sc.length)];
    return{x:Math.random()*W,y:Math.random()*H,r:Math.random()*2.2+.4,speed:Math.random()*.2+.04,twinkle:Math.random()*Math.PI*2,twinkleSpeed:Math.random()*.04+.015,color:c,drift:(Math.random()-.5)*.06};
  });
  function resetShoot(){return{x:Math.random()*W,y:Math.random()*H*.5,vx:-(Math.random()*6+4),vy:Math.random()*3+1.5,len:Math.random()*100+60,alpha:0,life:0,maxLife:Math.random()*60+40,color:sc[Math.floor(Math.random()*sc.length)]};}
  const shoots=Array.from({length:5},resetShoot);
  const orbs=[
    {x:W*.15,y:H*.2,vx:.22,vy:.14,r:240,r2:[255,50,100]},{x:W*.82,y:H*.12,vx:-.15,vy:.25,r:280,r2:[130,60,255]},
    {x:W*.5,y:H*.75,vx:.28,vy:-.18,r:200,r2:[0,210,150]},{x:W*.08,y:H*.82,vx:.12,vy:-.22,r:260,r2:[255,140,0]},
    {x:W*.92,y:H*.6,vx:-.25,vy:.13,r:180,r2:[0,180,255]},{x:W*.45,y:H*.35,vx:.18,vy:.2,r:220,r2:[255,60,200]},
  ];
  function draw(){
    ctx.fillStyle='#070714';ctx.fillRect(0,0,W,H);
    orbs.forEach(o=>{
      o.x+=o.vx;o.y+=o.vy;
      if(o.x<-o.r||o.x>W+o.r)o.vx*=-1;if(o.y<-o.r||o.y>H+o.r)o.vy*=-1;
      const[r,g,b]=o.r2,g2=ctx.createRadialGradient(o.x,o.y,0,o.x,o.y,o.r);
      g2.addColorStop(0,`rgba(${r},${g},${b},.28)`);g2.addColorStop(.4,`rgba(${r},${g},${b},.13)`);g2.addColorStop(.75,`rgba(${r},${g},${b},.05)`);g2.addColorStop(1,`rgba(${r},${g},${b},0)`);
      ctx.fillStyle=g2;ctx.beginPath();ctx.arc(o.x,o.y,o.r,0,Math.PI*2);ctx.fill();
    });
    shoots.forEach((s,i)=>{
      s.life++;s.x+=s.vx;s.y+=s.vy;
      s.alpha=s.life<15?s.life/15:s.life>s.maxLife?0:1-(s.life-s.maxLife*.7)/(s.maxLife*.3);
      if(s.life>s.maxLife||s.x<-200||s.y>H+50){shoots[i]=resetShoot();return;}
      const[r,g,b]=s.color,tx=s.x+Math.cos(Math.atan2(s.vy,s.vx)+Math.PI)*s.len,ty=s.y+Math.sin(Math.atan2(s.vy,s.vx)+Math.PI)*s.len;
      const sg=ctx.createLinearGradient(s.x,s.y,tx,ty);
      sg.addColorStop(0,`rgba(${r},${g},${b},${s.alpha*.9})`);sg.addColorStop(1,`rgba(${r},${g},${b},0)`);
      ctx.strokeStyle=sg;ctx.lineWidth=1.5;ctx.beginPath();ctx.moveTo(s.x,s.y);ctx.lineTo(tx,ty);ctx.stroke();
      ctx.beginPath();ctx.arc(s.x,s.y,2,0,Math.PI*2);ctx.fillStyle=`rgba(255,255,255,${s.alpha})`;ctx.fill();
    });
    stars.forEach(s=>{
      s.y-=s.speed;s.x+=s.drift;s.twinkle+=s.twinkleSpeed;
      if(s.y<-3){s.y=H+3;s.x=Math.random()*W;}
      if(s.x<-3)s.x=W+3;if(s.x>W+3)s.x=-3;
      const alpha=.5+.5*Math.abs(Math.sin(s.twinkle)),[r,g,b]=s.color;
      if(s.r>1.5){
        ctx.save();ctx.translate(s.x,s.y);ctx.fillStyle=`rgba(${r},${g},${b},${alpha})`;ctx.beginPath();
        for(let p=0;p<5;p++){const a=p*Math.PI*2/5-Math.PI/2,a2=a+Math.PI/5;ctx.lineTo(Math.cos(a)*s.r*1.8,Math.sin(a)*s.r*1.8);ctx.lineTo(Math.cos(a2)*s.r*.8,Math.sin(a2)*s.r*.8);}
        ctx.closePath();ctx.fill();ctx.restore();
      } else {ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fillStyle=`rgba(${r},${g},${b},${alpha})`;ctx.fill();}
    });
    requestAnimationFrame(draw);
  }
  draw();
})();
 
