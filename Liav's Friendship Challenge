function doSingleDelete(){
  const typed=document.getElementById('singleDelCode').value.trim();
  if(!challenge.deleteCode || typed===challenge.deleteCode){
    const key=challenge.type==='public'?pubScores(challenge.id):privScores(challenge.code);
    del(key);
    if(challenge.type==='public'){
      publicChallenges=publicChallenges.filter(c=>c.id!==challenge.id);
      store(PUB_KEY,publicChallenges);
    } else {
      del(privKey(challenge.code));
    }
    document.getElementById('deleteModal').classList.add('hidden');
    challenge=null; scores=[];
    showScreen('home');
  } else {
    alert('קוד מחיקה שגוי. האתגר לא נמחק.');
  }
}
 
function renderDeleteModal(tab){
  const cols=['#3ef7a0','#00e5ff','#ffb347','#ff6aad','#cc99ff'];
  const bgs=['rgba(46,247,160,.08)','rgba(0,229,255,.08)','rgba(255,179,71,.08)','rgba(255,106,173,.08)','rgba(204,153,255,.08)'];
  let pubRows='';
  const pubList=load(PUB_KEY)||[];
  if(pubList.length===0){
    pubRows='<div class="empty" style="padding:12px 0">אין אתגרים ציבוריים</div>';
  } else {
    pubList.forEach((c,i)=>{
      const clr=cols[i%cols.length],bg=bgs[i%bgs.length];
      pubRows+=`<div class="del-row" id="delrow_${c.id}" style="border:1.5px solid rgba(255,255,255,.1);background:rgba(255,255,255,.03)">
        <div style="flex:1;min-width:0">
          <div style="font-family:'Fredoka One',cursive;color:${clr};font-size:.88rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${c.title}</div>
          <div style="color:rgba(255,255,255,.38);font-size:.7rem">${c.creatorName}</div>
        </div>
        <input class="del-inp" id="delcode_${c.id}" placeholder="קוד מחיקה" oninput="checkDelMatch('${c.id}','${c.deleteCode}')">
        <span id="delcheck_${c.id}" style="color:#2ecc71;display:none">✓</span>
      </div>`;
    });
    pubRows+=`<button class="btn btn-danger" style="margin-top:12px" onclick="doDeleteByCodes()">🗑️ מחק עם קוד נכון</button>`;
  }
 
  document.getElementById('modal-body').innerHTML=`
    <div class="tab-row">
      <button class="tab-btn" id="tab-pub" onclick="renderDeleteModal('public')" style="border:1.5px solid ${tab==='public'?'#3ef7a0':'rgba(255,255,255,.1)'};background:${tab==='public'?'rgba(46,247,160,.12)':'transparent'};color:${tab==='public'?'#3ef7a0':'#a8b8d8'}">🌍 ציבורי</button>
      <button class="tab-btn" id="tab-priv" onclick="renderDeleteModal('private')" style="border:1.5px solid ${tab==='private'?'#cc99ff':'rgba(255,255,255,.1)'};background:${tab==='private'?'rgba(204,153,255,.12)':'transparent'};color:${tab==='private'?'#cc99ff':'#a8b8d8'}">🔐 פרטי</button>
    </div>
    ${tab==='public'?`
      <div style="color:#c0c8e8;font-size:.82rem;margin-bottom:12px">הכנס קוד מחיקה לצד כל אתגר. קוד שגוי — לא נמחק.</div>
      ${pubRows}
    `:`
      <div style="color:#c0c8e8;font-size:.82rem;margin-bottom:14px">הכנס קוד גישה וקוד מחיקה. שניהם חייבים להיות נכונים.</div>
      <label class="label" style="color:#cc99ff">קוד גישה לאתגר (6 תווים)</label>
      <input class="inp" id="privDelAccess" placeholder="6 תווים..." style="margin-bottom:12px;letter-spacing:4px;text-transform:uppercase;border-color:rgba(204,153,255,.4)" oninput="this.value=this.value.toUpperCase().slice(0,6)">
      <label class="label" style="color:#ff6aad">קוד מחיקה סודי</label>
      <input class="inp" id="privDelSecret" placeholder="קוד מחיקה שהגדרת..." style="margin-bottom:16px;border-color:rgba(255,106,173,.4)">
      <button class="btn btn-danger" onclick="doDeletePrivate()">🗑️ מחק אתגר פרטי לכולם</button>
    `}`;
}
 
function checkDelMatch(id,correctCode){
  const typed=document.getElementById(`delcode_${id}`).value.trim();
  const row=document.getElementById(`delrow_${id}`);
  const check=document.getElementById(`delcheck_${id}`);
  const inp=document.getElementById(`delcode_${id}`);
  if(typed===correctCode){
    row.style.border='1.5px solid #2ecc71';
    row.style.background='rgba(46,204,113,.1)';
    check.style.display='inline';
    inp.style.borderColor='#2ecc71';
    inp.style.color='#3ef7a0';
  } else {
    row.style.border='1.5px solid rgba(255,255,255,.1)';
    row.style.background='rgba(255,255,255,.03)';
    check.style.display='none';
    inp.style.borderColor='rgba(120,100,255,.35)';
    inp.style.color='#e2e8f0';
  }
}
 
function doDeleteByCodes(){
  const pubList=load(PUB_KEY)||[];
  let deleted=0;
  const remaining=pubList.filter(c=>{
    const inp=document.getElementById(`delcode_${c.id}`);
    if(!inp) return true;
    if(inp.value.trim()===c.deleteCode){del(pubScores(c.id));deleted++;return false;}
    return true;
  });
  if(deleted===0) return alert('אף קוד לא תואם. שום דבר לא נמחק.');
  store(PUB_KEY,remaining);
  publicChallenges=remaining;
  document.getElementById('deleteModal').classList.add('hidden');
  alert(`✅ ${deleted} אתגרים נמחקו לכולם!`);
  renderHome();
}
 
function doDeletePrivate(){
  const code=(document.getElementById('privDelAccess')?.value||'').trim().toUpperCase();
  const secret=(document.getElementById('privDelSecret')?.value||'').trim();
  if(!code) return alert('הכנס קוד גישה');
  if(!secret) return alert('הכנס קוד מחיקה');
  const data=load(privKey(code));
  if(!data) return alert('לא נמצא אתגר פרטי עם הקוד הזה.');
  if(data.deleteCode!==secret) return alert('קוד המחיקה שגוי. האתגר לא נמחק.');
  del(privScores(code));
  del(privKey(code));
  document.getElementById('deleteModal').classList.add('hidden');
  alert('✅ האתגר הפרטי נמחק לכולם!');
}
 
